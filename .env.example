# =============================================================================
# Vorlage für Umgebungsvariablen – Dokumentenprüfung GA IV
# =============================================================================
#
# Benennung (Next.js):
#   .env.example   → Vorlage im Repository (ohne echte Keys)
#   .env.local     → Ihre lokale Konfiguration (gitignored, hier Keys eintragen)
#
# Einrichtung lokal:
#   1. Diese Datei kopieren:  cp .env.example .env.local   (Windows: copy .env.example .env.local)
#   2. In .env.local GROK_API_KEY eintragen
#   3. Dev-Server neu starten: npm run dev
#
# Ohne GROK_API_KEY läuft die App im Mock-Modus (Demo-Daten).
# =============================================================================

# Pflicht nur für echte KI-Analyse (xAI / GROK)
GROK_API_KEY= 

# Optional – Standard: https://api.x.ai/v1/chat/completions
GROK_API_URL=

# Optional – Standard: grok-3-latest (xAI; grok-2-latest ist veraltet)
GROK_MODEL=grok-3-latest
